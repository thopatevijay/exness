{
  "info": {
    "_postman_id": "3e8f0a2b-1f8a-4d4e-9a9c-stage05auth",
    "name": "Exness V0 / 05 - Auth",
    "description": "Stage 05 validation requests. Run top-to-bottom; the Signin test auto-saves the JWT into the `token` collection variable, which subsequent requests use.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000", "type": "string" },
    { "key": "healthUrl", "value": "http://localhost:9005", "type": "string" },
    { "key": "email", "value": "postman@test.local", "type": "string" },
    { "key": "password", "value": "hunter2hunter", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "V5.1  Signup (201 + userId)",
      "request": {
        "method": "POST",
        "header": [{ "key": "content-type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/user/signup", "host": ["{{baseUrl}}"], "path": ["api", "v1", "user", "signup"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 201 on first signup', function () {",
              "  if (pm.response.code === 403) {",
              "    console.log('user already exists — that is fine if you have run this before');",
              "    return;",
              "  }",
              "  pm.response.to.have.status(201);",
              "  const body = pm.response.json();",
              "  pm.expect(body.userId).to.be.a('string');",
              "  pm.collectionVariables.set('userId', body.userId);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "V5.2  Signup duplicate (403)",
      "request": {
        "method": "POST",
        "header": [{ "key": "content-type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/user/signup", "host": ["{{baseUrl}}"], "path": ["api", "v1", "user", "signup"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 403', () => pm.response.to.have.status(403));",
              "pm.test('message = Error while signing up', () => {",
              "  pm.expect(pm.response.json().message).to.eql('Error while signing up');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "V5.3  Signup invalid input (411)",
      "request": {
        "method": "POST",
        "header": [{ "key": "content-type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"not-an-email\",\n  \"password\": \"x\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/user/signup", "host": ["{{baseUrl}}"], "path": ["api", "v1", "user", "signup"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 411', () => pm.response.to.have.status(411));",
              "pm.test('message = Incorrect inputs', () => {",
              "  pm.expect(pm.response.json().message).to.eql('Incorrect inputs');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "V5.4  Signin (200 + JWT; saves token)",
      "request": {
        "method": "POST",
        "header": [{ "key": "content-type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/user/signin", "host": ["{{baseUrl}}"], "path": ["api", "v1", "user", "signin"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "const token = pm.response.json().token;",
              "pm.expect(token).to.match(/^eyJ/);",
              "pm.collectionVariables.set('token', token);",
              "console.log('token saved:', token.slice(0, 30) + '...');"
            ]
          }
        }
      ]
    },
    {
      "name": "V5.5  Signin wrong password (403)",
      "request": {
        "method": "POST",
        "header": [{ "key": "content-type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"wrong\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/user/signin", "host": ["{{baseUrl}}"], "path": ["api", "v1", "user", "signin"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 403', () => pm.response.to.have.status(403));",
              "pm.test('message = Incorrect credentials', () => {",
              "  pm.expect(pm.response.json().message).to.eql('Incorrect credentials');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "V5.6  Balance unauth (401)",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/api/v1/user/balance", "host": ["{{baseUrl}}"], "path": ["api", "v1", "user", "balance"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 401', () => pm.response.to.have.status(401));",
              "pm.test('code = AUTH_REQUIRED', () => {",
              "  pm.expect(pm.response.json().error.code).to.eql('AUTH_REQUIRED');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "V5.7  Balance auth (200 + usd_balance)",
      "request": {
        "method": "GET",
        "header": [{ "key": "authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{baseUrl}}/api/v1/user/balance", "host": ["{{baseUrl}}"], "path": ["api", "v1", "user", "balance"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "pm.test('usd_balance = 500000', () => {",
              "  pm.expect(pm.response.json().usd_balance).to.eql(500000);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "V5.8  Health (200 + db+redis ok)",
      "request": {
        "method": "GET",
        "url": { "raw": "{{healthUrl}}/health", "host": ["{{healthUrl}}"], "path": ["health"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.expect(body.checks.db).to.eql('ok');",
              "pm.expect(body.checks.redis).to.eql('ok');"
            ]
          }
        }
      ]
    },
    {
      "name": "V5.9  Metrics (prom-client output)",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/metrics", "host": ["{{baseUrl}}"], "path": ["metrics"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "pm.test('exposes process_cpu_seconds_total', () => {",
              "  pm.expect(pm.response.text()).to.include('process_cpu_seconds_total');",
              "});",
              "pm.test('exposes custom trades_opened_total', () => {",
              "  pm.expect(pm.response.text()).to.include('trades_opened_total');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "V5.10 Request-ID propagation",
      "request": {
        "method": "GET",
        "header": [
          { "key": "authorization", "value": "Bearer {{token}}" },
          { "key": "x-request-id", "value": "my-test-12345" }
        ],
        "url": { "raw": "{{baseUrl}}/api/v1/user/balance", "host": ["{{baseUrl}}"], "path": ["api", "v1", "user", "balance"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "pm.test('echoes x-request-id', () => {",
              "  pm.expect(pm.response.headers.get('x-request-id')).to.eql('my-test-12345');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "V5.11 Rate limit (run 12x via Runner; 11th should be 429)",
      "request": {
        "method": "POST",
        "header": [{ "key": "content-type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"wrong\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/user/signin", "host": ["{{baseUrl}}"], "path": ["api", "v1", "user", "signin"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Use the Collection Runner: select ONLY this request, iterations = 12.",
              "// First ~10 attempts return 403 (Incorrect credentials); attempts past the",
              "// limit return 429. Window is 10 requests per 10 minutes per IP.",
              "pm.test('status 403 or 429', () => {",
              "  pm.expect([403, 429]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
