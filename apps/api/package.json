    "@exness/shared": "workspace:*",
    "bcrypt": "6.0.0",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "express": "5.2.1",
    "express-rate-limit": "8.3.2",
    "helmet": "8.1.0",
    "ioredis": "5.10.1",
    "jsonwebtoken": "9.0.3",
    "pino-http": "11.0.0",
