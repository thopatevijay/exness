    "ws": "8.20.0"
  },
  "devDependencies": {
    "@exness/eslint-config": "workspace:*",
    "@exness/typescript-config": "workspace:*",
    "@types/node": "24.11.1",
    "@types/ws": "8.18.1",
    "eslint": "10.2.1",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  }
