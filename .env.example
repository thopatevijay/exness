NODE_ENV=development
LOG_LEVEL=info

DATABASE_URL=postgres://postgres:postgres@localhost:5434/exness
REDIS_URL=redis://localhost:6379

# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-32-byte-hex
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CSV of origins allowed by CORS. Empty = same-origin only. NEVER use '*'.
ALLOWED_ORIGINS=http://localhost:3001

BINANCE_WS_URL=wss://stream.binance.com:9443/stream
BINANCE_SYMBOLS=btcusdt,ethusdt,solusdt

API_PORT=8000
API_HEALTH_PORT=9005
WS_SERVER_PORT=8001
WS_SERVER_HEALTH_PORT=9001
PRICE_POLLER_HEALTH_PORT=9002
BATCH_UPLOADER_HEALTH_PORT=9003
LIQUIDATION_WORKER_HEALTH_PORT=9004
